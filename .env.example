# Gov-only backend. No external provider keys are used.
# Set a real contact URL/email per NOAA/NWS API etiquette.
NWS_USER_AGENT=PolliNation/1.0 (https://your-domain.example; you@example.com)
CACHE_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
# Empty by default because the native iOS app does not need browser CORS.
# Example for web dashboards only: ALLOWED_ORIGINS=https://your-domain.example
ALLOWED_ORIGINS=
